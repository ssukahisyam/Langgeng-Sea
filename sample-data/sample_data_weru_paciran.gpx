<?xml version="1.0" encoding="UTF-8"?>
<gpx version="1.1" creator="Langgeng Sea Sample"
     xmlns="http://www.topografix.com/GPX/1/1"
     xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd">

  <!-- ================================================================ -->
  <!-- 5 PENANDA (waypoints) di sekitar Desa Weru, Paciran, Lamongan     -->
  <!-- ================================================================ -->

  <wpt lat="-6.8700" lon="112.3500">
    <name>Pelabuhan Weru</name>
    <desc>Titik berangkat melaut dari Desa Weru</desc>
  </wpt>

  <wpt lat="-6.8350" lon="112.3850">
    <name>Karang Tengah</name>
    <desc>Spot mancing kakap merah, kedalaman ~25m</desc>
  </wpt>

  <wpt lat="-6.8100" lon="112.4200">
    <name>Rumpon Utara</name>
    <desc>Rumpon ikan tongkol, ramai pagi hari</desc>
  </wpt>

  <wpt lat="-6.8450" lon="112.3200">
    <name>Pangkalan Es</name>
    <desc>Lokasi ambil es batu sebelum melaut</desc>
  </wpt>

  <wpt lat="-6.8550" lon="112.4500">
    <name>Spot Cumi-cumi</name>
    <desc>Hot spot cumi malam hari, dekat lampu nelayan</desc>
  </wpt>

  <!-- ================================================================ -->
  <!-- 5 JALUR TRACKING (tracks) — simulasi tarikan trawl 5 trip berbeda -->
  <!-- ================================================================ -->

  <!-- Track 1: Tarikan Utara - dari Pelabuhan ke Rumpon Utara -->
  <trk>
    <name>Tarikan #1 - Jalur Utara</name>
    <trkseg>
      <trkpt lat="-6.8700" lon="112.3500"><time>2026-05-10T05:00:00Z</time><speed>2.5</speed></trkpt>
